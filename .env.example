# Neon Postgres connection string
# Get from: neon.tech -> your project -> Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API key for Claude agent calls
# Get from: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Product Hunt API token (optional — disables PH signals if absent)
# Get from: api.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=
